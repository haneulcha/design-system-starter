{
  "version": 1,
  "scope": [
    "buttons",
    "inputs",
    "cards",
    "badges",
    "tabs",
    "avatar"
  ],
  "variants": {
    "buttons": [
      "primary",
      "secondary",
      "tertiary",
      "ghost",
      "outline",
      "text",
      "icon",
      "danger"
    ],
    "inputs": [
      "text",
      "search",
      "textarea"
    ],
    "cards": [
      "default",
      "outlined",
      "elevated",
      "filled"
    ],
    "badges": [
      "solid",
      "subtle",
      "outline"
    ],
    "tabs": [
      "underline",
      "pill",
      "segmented"
    ],
    "avatar": [
      "circle"
    ]
  },
  "states": [
    "default",
    "hover",
    "active",
    "focus",
    "disabled",
    "error"
  ],
  "sizeVariants": [
    "sm",
    "md",
    "lg"
  ],
  "modifiers": [
    "onDark",
    "onLight",
    "pill",
    "capsule",
    "icon"
  ],
  "rules": [
    "feature-card / pricing-card / hero-card / testimonial-card / etc. \u2192 cards (variant=default unless attrs say otherwise) \u2014 corpus uses these as de-facto card data even though they are page-slotted",
    "cta-band-* \u2192 _excluded (full-bleed page-architecture, not a button)",
    "*-on-dark / *-on-light \u2192 modifier: 'onDark' or 'onLight' (not a state)",
    "*-active / *-pressed \u2192 state: 'active'",
    "*-disabled \u2192 state: 'disabled'",
    "*-focus / *-focused \u2192 state: 'focus'",
    "*-pill / *-capsule / *-rounded-full \u2192 modifier: 'pill' (radius treatment, not variant)",
    "*-icon-* / icon-button-* \u2192 variant: 'icon'",
    "Brand-color names (coral, purple, green, blue, orange, red, sand) \u2192 variant=primary (color is per-system not v1 variant)",
    "*-text / text-link / button-tertiary-text \u2192 variant: 'text'",
    "*-ghost / *-transparent / *-glass \u2192 variant: 'ghost'",
    "*-outline / *-outlined / *-bordered \u2192 variant: 'outline'",
    "*-tertiary \u2192 variant: 'tertiary'",
    "*-secondary \u2192 variant: 'secondary'",
    "*-primary / unprefixed brand-color \u2192 variant: 'primary'",
    "_default for groups with no sub-variant \u2192 variant=primary, state=default, sizeVariant=md (per system's representative button)",
    "filter-chip \u2192 tabs:pill (chips serve as filter-tab role in corpus)",
    "card-tile / *-tile \u2192 cards:default (tile is naming, not structure)",
    "callout-card-* / cookie-consent-card \u2192 cards:default",
    "code-block / code-window-card / agent-console-card \u2192 cards:default (code-shell wraps a card)",
    "ide-mockup-card / device-mockup-card / hero-app-mockup-card \u2192 cards:default (mockup wraps a card)",
    "audio-waveform-card / gradient-orb-card \u2192 cards:default (brand-distinctive, but generic card structure)",
    "search-bar-pill \u2192 inputs:search modifier:pill",
    "newsletter-input-band \u2192 _excluded (band is page-architecture)",
    "ai-chat-input \u2192 inputs:text modifier:multiline",
    "date-picker-day \u2192 _excluded (date picker is a future component, not v1 input)",
    "avatar-circle \u2192 avatar:circle"
  ],
